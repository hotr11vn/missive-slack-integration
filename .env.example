# ─── Required ───────────────────────────────────────────────
# Slack Bot User OAuth Token (starts with xoxb-)
# Obtain from: https://api.slack.com/apps → Your App → OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-your-token-here

# ─── Optional ──────────────────────────────────────────────
# A shared secret to verify requests from the Missive iFrame.
# Set this to any random string, then append it as ?token=<value>
# when configuring the integration URL inside Missive.
INTEGRATION_SECRET=change-me-to-a-random-string
